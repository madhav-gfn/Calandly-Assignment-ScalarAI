# ── Database ─────────────────────────────────────────────────
# PostgreSQL connection string (Neon, Supabase, local, etc.)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/calendly_clone"

# ── Server ───────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Auth (hardcoded default user) ────────────────────────────
# UUID of the seeded admin user. After running `npx prisma db seed`,
# copy the printed user ID here.
DEFAULT_USER_ID=your-user-uuid-here

# ── CORS ─────────────────────────────────────────────────────
# URL of the frontend app (no trailing slash)
FRONTEND_URL=http://localhost:5173

# ── Email (production only) ───────────────────────────────────
# If NODE_ENV=production, these SMTP vars are required.
# In development, Ethereal (fake) SMTP is used automatically.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
